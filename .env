# ══════════════════════════════════════════════════════
# Voice AI Production — Environment Variables
# Copy to .env and fill in your keys
# ══════════════════════════════════════════════════════

# ─── LLM Providers ────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
LLM_PRIMARY_MODEL=gpt-4o
LLM_FALLBACK_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ─── STT (Speech-to-Text) ─────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-key-here
STT_PRIMARY=deepgram          # deepgram | whisper
STT_FALLBACK=whisper
WHISPER_MODEL_SIZE=base       # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu            # cpu | cuda

# ─── TTS (Text-to-Speech) ─────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-key-here
TTS_PRIMARY=elevenlabs        # elevenlabs | coqui | gtts
TTS_FALLBACK=gtts
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# ─── Redis (Context Store) ────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=3600        # seconds
REDIS_MAX_TURNS=20

# ─── PostgreSQL (Semantic Memory) ─────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=voiceai
POSTGRES_USER=voiceai
POSTGRES_PASSWORD=devpassword
PGVECTOR_DIMENSIONS=1536

# ─── Kafka ────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=voice-ai-consumers
KAFKA_AUTO_OFFSET_RESET=latest

# ─── Security ─────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-256-bit-secret
JWT_ALGORITHM=RS256
JWT_EXPIRY_MINUTES=15
ENCRYPTION_KEY=change-this-to-a-random-32-byte-key

# ─── Fraud Detection ──────────────────────────────────
FRAUD_THRESHOLD_LOW=0.3
FRAUD_THRESHOLD_ELEVATED=0.6
FRAUD_THRESHOLD_HIGH=0.85
FRAUD_MODEL_PATH=/models/fraud_xgb_v1.pkl

# ─── Urgency Escalation ───────────────────────────────
URGENCY_ESCALATION_WEBHOOK=https://your-webhook.com/escalate
URGENCY_THRESHOLD=0.75
HUMAN_HANDOFF_QUEUE=urgent_queue

# ─── Monitoring ───────────────────────────────────────
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_LEVEL=INFO
SENTRY_DSN=

# ─── Audio Processing ─────────────────────────────────
AUDIO_CHUNK_MS=100
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
MAX_SESSION_DURATION=1800     # 30 minutes

# ─── Feature Flags ────────────────────────────────────
ENABLE_EMOTION_DETECTION=true
ENABLE_FRAUD_SCORING=true
ENABLE_URGENCY_ESCALATION=true
ENABLE_SEMANTIC_MEMORY=true
ENABLE_VOICEPRINT_VERIFY=false  # requires enrollment
